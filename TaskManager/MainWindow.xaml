<Window x:Class="TaskManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TaskManager"
        mc:Ignorable="d"
        xmlns:ctrl="clr-namespace:TaskManager.Controls"
        Title="Task Manager"
        Height="600"
        Width="950">
    <DockPanel>

        <Menu DockPanel.Dock="Top">

            <MenuItem Header="Файл">

                <MenuItem Header="Загрузить JSON"
                      Click="LoadJson_Click"/>

                <MenuItem Header="Сохранить JSON"
                      Click="SaveJson_Click"/>

                <Separator/>

                <MenuItem Header="Загрузить XML"
                      Click="LoadXml_Click"/>

                <MenuItem Header="Сохранить XML"
                      Click="SaveXml_Click"/>

            </MenuItem>

            <MenuItem Header="Задача">

                <MenuItem Header="Добавить"
                      Click="Add_Click"/>

                <MenuItem Header="Изменить"
                      Click="Edit_Click"/>

                <MenuItem Header="Удалить"
                      Click="Delete_Click"/>

            </MenuItem>

        </Menu>

        <StackPanel DockPanel.Dock="Top"
                    Orientation="Horizontal">

            <TextBox x:Name="tbSearch"
                     Width="250"/>

            <Button Content="Поиск"
                    Click="Search_Click"/>

            <ComboBox x:Name="cbFilter"
                      Width="150"/>

            <Button Content="Фильтр"
                    Click="Filter_Click"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Right">

            <Button Content="Добавить"
                    Click="Add_Click"/>

            <Button Content="Изменить"
                    Click="Edit_Click"/>

            <Button Content="Удалить"
                    Click="Delete_Click"/>
        </StackPanel>

        <ctrl:StatisticsControl x:Name="stats"
                                DockPanel.Dock="Bottom"/>

        <DataGrid x:Name="tasksGrid"
          AutoGenerateColumns="False"
          Margin="10"
          IsReadOnly="True"
          CanUserAddRows="False"
          SelectionMode="Single"
          GridLinesVisibility="Horizontal">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Название"
                            Binding="{Binding Title}"
                            Width="*"/>

                <DataGridTextColumn Header="Описание"
                            Binding="{Binding Description}"
                            Width="2*"/>

                <DataGridTextColumn Header="Приоритет"
                            Binding="{Binding Priority}"
                            Width="*"/>

                <DataGridTextColumn Header="Срок выполнения"
                            Binding="{Binding DueDate, StringFormat=dd.MM.yyyy}"
                            Width="*"/>

                <DataGridTextColumn Header="Статус"
                            Binding="{Binding Status}"
                            Width="*"/>

            </DataGrid.Columns>

        </DataGrid>

    </DockPanel>
</Window>
